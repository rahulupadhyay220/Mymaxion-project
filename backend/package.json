{
  "name": "mymaxion-backend",
  "version": "1.0.0",
  "description": "Scalable backend for MyMaxion corporate website",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "lint": "eslint .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "docker:build": "docker build -t mymaxion-backend .",
    "docker:up": "docker-compose up --build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "nodemailer": "^6.9.3",
    "rss": "^1.2.2",
    "cheerio": "^1.0.0-rc.12"
  },
  "devDependencies": {
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.4",
    "supertest": "^6.3.3"
  }
}